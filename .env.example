# =========================
# App
# =========================
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
SWAGGER_ROUTE_PREFIX=/docs
CORS_ORIGIN=http://localhost:5173

# =========================
# Database
# =========================
DATABASE_URL=postgresql://postgres:1234@localhost:5432/datn

# =========================
# Auth / JWT
# =========================
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=typst-platform
JWT_AUDIENCE=typst-platform-users

# =========================
# Optional Redis / Queue / Cache
# =========================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =========================
# Typst / Compile
# =========================
TYPST_WORKDIR_ROOT=./var/typst-workdir
COMPILE_STORAGE_ROOT=./var/artifacts
COMPILE_TIMEOUT_MS=30000
MAX_COMPILE_CONCURRENCY=2

# =========================
# Upload / File Storage
# =========================
MAX_UPLOAD_SIZE_BYTES=10485760
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./var/storage

# =========================
# S3 / Object Storage (optional)
# =========================
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# =========================
# Google OAuth / SSO (optional)
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# =========================
# LDAP / SSO (optional)
# =========================
LDAP_URL=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=
LDAP_USER_FILTER=(mail={{email}})
LDAP_START_TLS=false

# =========================
# Collaboration / WebSocket
# =========================
WS_ALLOWED_ORIGIN=http://localhost:5173
COLLAB_SESSION_TTL_SECONDS=86400

# =========================
# Email / SMTP (optional)
# =========================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_SECURE=false

# =========================
# Logging / Observability
# =========================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# =========================
# Feature Flags (safe defaults)
# =========================
ENABLE_SWAGGER=true
ENABLE_GOOGLE_SSO=false
ENABLE_LDAP_SSO=false
ENABLE_COLLABORATION=true
ENABLE_ANALYTICS=true
ENABLE_QUOTA=true